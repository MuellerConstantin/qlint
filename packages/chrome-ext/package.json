{
  "name": "@qlint/chrome-ext",
  "version": "0.1.0",
  "description": "Chrome extension that lints and formats Qlik load scripts inline in the Qlik Sense Data Load Editor, powered by @qlint/core.",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/MuellerConstantin/qlint",
  "repository": {
    "type": "git",
    "url": "https://github.com/MuellerConstantin/qlint.git",
    "directory": "packages/chrome-ext"
  },
  "scripts": {
    "build": "tsdown && node -e \"require('node:fs').cpSync('public', 'dist', { recursive: true })\""
  },
  "dependencies": {
    "@qlint/core": "^0.1.0",
    "codemirror": "^5.65.18"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.3",
    "@types/codemirror": "^5.60.17",
    "chrome-types": "^0.1.0",
    "tsdown": "*",
    "typescript": "^5.6.0"
  }
}
