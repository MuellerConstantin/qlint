{
  "manifest_version": 3,
  "name": "qlint",
  "version": "0.1.0",
  "description": "Opinionated linting/formatting for Qlik script.",
  "permissions": ["scripting", "activeTab", "webNavigation"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Activate qlint on this site"
  },
  "icons": {
    "16": "images/qlint-16.png",
    "32": "images/qlint-32.png",
    "48": "images/qlint-48.png",
    "128": "images/qlint-128.png"
  }
}
