{
  "name": "qlint-vscode-ext",
  "displayName": "qlint",
  "version": "0.1.0",
  "description": "VS Code extension that lints and formats Qlik load scripts, powered by @qlint/core.",
  "private": true,
  "publisher": "MuellerConstantin",
  "homepage": "https://github.com/MuellerConstantin/qlint",
  "repository": {
    "type": "git",
    "url": "https://github.com/MuellerConstantin/qlint.git",
    "directory": "packages/vscode-ext"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Formatters"
  ],
  "icon": "images/qlint-128.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:qlik"
  ],
  "contributes": {
    "languages": [
      {
        "id": "qlik",
        "aliases": [
          "Qlik Script",
          "qlik",
          "qvs"
        ],
        "extensions": [
          ".qvs"
        ],
        "icon": {
          "light": "./images/file-icon.svg",
          "dark": "./images/file-icon.svg"
        }
      }
    ]
  },
  "scripts": {
    "build": "tsdown",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "@qlint/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "tsdown": "*",
    "typescript": "^5.6.0"
  }
}
