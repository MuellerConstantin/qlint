// Field unindented — 1 finding (Id).
[A]:
Load
Id
From X;

// Field overindented — 1 finding (Total).
[B]:
Load
        Total
From X;

// Clause indented when it shouldn't be — 1 finding (From).
[C]:
Load
    Id
    From X;

// Mixed: one field unindented, one clause overindented — 2 findings.
[D]:
Load
    A,
B,
    C
    From X;

// Nested in a Sub. base = one step (the Load line carries one step of outer
// indent). Field expected two steps, clause expected one step.
Sub foo
    [E]:
    Load
    Id
        From X;
End Sub

// Field indented with a tab under the default space style — 1 finding.
[F]:
Load
	Id
From X;
