{
  "name": "@qlint/core",
  "version": "0.1.0",
  "description": "Opinionated linting/formatting utilities for Qlik Script (QVS)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/MuellerConstantin/qlint",
  "repository": {
    "type": "git",
    "url": "https://github.com/MuellerConstantin/qlint.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chevrotain": "^11.0.3"
  },
  "devDependencies": {
    "tsdown": "*",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^25.9.1"
  }
}
