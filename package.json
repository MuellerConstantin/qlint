{
  "name": "qlint",
  "version": "0.1.0-dev.1",
  "description": "Opinionated linting/formatting utilities for Qlik Script (QVS)",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @qlint/core && npm run build -w @qlint/cli && npm run build -w @qlint/chrome-ext",
    "build:core": "npm run build -w @qlint/core",
    "build:cli": "npm run build -w @qlint/cli",
    "build:chrome-ext": "npm run build -w @qlint/chrome-ext",
    "test": "npm test -w @qlint/core",
    "test:core": "npm test -w @qlint/core",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
